# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Option 1: Comma-separated (easier)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend-domain.vercel.app

# Option 2: JSON array (also works)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://your-frontend-domain.vercel.app"]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
